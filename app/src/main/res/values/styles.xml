<resources>
    <style name="Widget.MangaTranslator.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_rounded</item>
        <item name="android:textColor">?attr/buttonTextColor</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">50dp</item>
        <item name="android:paddingStart">18dp</item>
        <item name="android:paddingEnd">18dp</item>
    </style>

    <style name="Widget.MangaTranslator.Title" parent="TextAppearance.AppCompat.Title">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">?attr/colorAccent</item>
    </style>

    <style name="Widget.MangaTranslator.HeroTitle" parent="TextAppearance.AppCompat.Large">
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="Widget.MangaTranslator.HeroSubtitle" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/white_85</item>
    </style>

    <style name="Widget.MangaTranslator.SectionLabel" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textColor">?attr/mutedTextColor</item>
    </style>

    <style name="Widget.MangaTranslator.CardTitle" parent="TextAppearance.AppCompat.Medium">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">?attr/colorAccent</item>
    </style>

    <style name="Widget.MangaTranslator.BodyMuted" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">?attr/mutedTextColor</item>
    </style>

    <style name="Widget.MangaTranslator.Input" parent="">
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusTopStart">22dp</item>
        <item name="boxCornerRadiusTopEnd">22dp</item>
        <item name="boxCornerRadiusBottomStart">22dp</item>
        <item name="boxCornerRadiusBottomEnd">22dp</item>
        <item name="boxStrokeColor">?attr/outlineColor</item>
        <item name="hintTextColor">?attr/mutedTextColor</item>
    </style>

    <style name="ThemeOverlay.MangaTranslator.AlertDialog" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@drawable/bg_dialog_surface</item>
        <item name="android:textColorPrimary">?attr/colorAccent</item>
        <item name="android:textColorSecondary">?attr/mutedTextColor</item>
        <item name="buttonBarButtonStyle">@style/Widget.MangaTranslator.Button</item>
        <item name="android:buttonBarButtonStyle">@style/Widget.MangaTranslator.Button</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.MangaTranslator.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.MangaTranslator.Button</item>
        <item name="buttonBarNeutralButtonStyle">@style/Widget.MangaTranslator.Button</item>
        <item name="android:windowMinWidthMajor">92%</item>
        <item name="android:windowMinWidthMinor">92%</item>
    </style>

</resources>
