<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_dialog_card"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/translation_provider_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="@style/Widget.MangaTranslator.SectionLabel"
            android:textColor="?attr/colorAccent" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/translation_provider_enabled_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/multi_provider_scheduling_enabled"
            android:textColor="?attr/dialogTextColor" />

        <TextView
            android:id="@+id/translation_provider_delete_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:minHeight="40dp"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:text="@string/multi_provider_scheduling_delete_action"
            android:textColor="?attr/colorAccent"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/translation_provider_fields_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/api_url_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/translation_provider_api_url_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/api_key_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/translation_provider_api_key_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/model_name_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/translation_provider_model_name_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/multi_provider_scheduling_weight_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/translation_provider_weight_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</LinearLayout>
