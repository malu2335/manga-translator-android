<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/custom_request_param_enabled_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/custom_request_params_enabled"
        android:textColor="?attr/dialogTextColor" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MangaTranslator.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/custom_request_param_key_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/custom_request_param_key_input"
            style="@style/Widget.MangaTranslator.DialogEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MangaTranslator.Input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:hint="@string/custom_request_param_value_hint">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/custom_request_param_value_input"
            style="@style/Widget.MangaTranslator.DialogEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:minLines="2" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button
        android:id="@+id/custom_request_param_delete_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/custom_request_params_delete" />
</LinearLayout>
