<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/normal_bubble_render_settings_note"
            android:textColor="?attr/dialogHintTextColor"
            android:textSize="13sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/normal_bubble_shrink_percent_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/normal_bubble_shrink_percent_input"
                style="@style/Widget.MangaTranslator.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/normal_bubble_opacity_percent_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/normal_bubble_opacity_percent_input"
                style="@style/Widget.MangaTranslator.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/normal_bubble_free_shrink_percent_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/normal_bubble_free_shrink_percent_input"
                style="@style/Widget.MangaTranslator.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/normal_bubble_free_opacity_percent_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/normal_bubble_free_opacity_percent_input"
                style="@style/Widget.MangaTranslator.EditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/normal_bubble_min_area_per_char_label"
            android:textColor="?attr/dialogTextColor"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/normal_bubble_min_area_value_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/dialogHintTextColor"
            android:textSize="12sp" />

        <SeekBar
            android:id="@+id/normal_bubble_min_area_seekbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:max="100" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/normal_bubble_horizontal_text_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/text_layout_horizontal"
            android:textColor="?attr/dialogTextColor" />
    </LinearLayout>
</ScrollView>
