<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/floating_use_vl_direct_translate_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="?attr/dialogTextColor"
            android:text="@string/floating_use_vl_direct_translate" />

        <TextView
            android:id="@+id/floating_translate_vl_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/floating_use_vl_direct_translate_note"
            android:textAppearance="@style/Widget.MangaTranslator.BodyMuted" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/floating_proofreading_mode_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="?attr/dialogTextColor"
            android:text="@string/floating_proofreading_mode" />

        <TextView
            android:id="@+id/floating_proofreading_mode_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/floating_proofreading_mode_note"
            android:textAppearance="@style/Widget.MangaTranslator.BodyMuted" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/floating_auto_close_on_screen_change_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="?attr/dialogTextColor"
            android:text="@string/floating_auto_close_on_screen_change" />

        <TextView
            android:id="@+id/floating_auto_close_on_screen_change_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/floating_auto_close_on_screen_change_note"
            android:textAppearance="@style/Widget.MangaTranslator.BodyMuted" />

        <TextView
            android:id="@+id/floating_gesture_settings_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/floating_gesture_settings_title"
            android:textAppearance="@style/Widget.MangaTranslator.CardTitle" />

        <TextView
            android:id="@+id/floating_gesture_settings_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/floating_gesture_settings_note"
            android:textAppearance="@style/Widget.MangaTranslator.BodyMuted" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_single_tap_action_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_single_tap_action_hint"
            app:endIconMode="dropdown_menu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/floating_single_tap_action_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:importantForAutofill="no"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_double_tap_action_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_double_tap_action_hint"
            app:endIconMode="dropdown_menu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/floating_double_tap_action_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:importantForAutofill="no"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_long_press_action_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_long_press_action_hint"
            app:endIconMode="dropdown_menu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/floating_long_press_action_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:importantForAutofill="no"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_triple_tap_action_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_triple_tap_action_hint"
            app:endIconMode="dropdown_menu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/floating_triple_tap_action_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:importantForAutofill="no"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_language_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_language_hint"
            app:endIconMode="dropdown_menu">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/floating_language_input"
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:importantForAutofill="no"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_vl_translate_concurrency_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_vl_translate_concurrency_hint">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:id="@+id/floating_vl_translate_concurrency_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_api_timeout_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_api_timeout_hint">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:id="@+id/floating_api_timeout_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_api_url_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_api_url_hint">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:id="@+id/floating_api_url_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_api_key_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_api_key_hint">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:id="@+id/floating_api_key_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/floating_model_name_layout"
            style="@style/Widget.MangaTranslator.Input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/floating_model_name_hint">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/Widget.MangaTranslator.DialogEditText"
                android:id="@+id/floating_model_name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/floating_translate_settings_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/floating_translate_settings_note"
            android:textAppearance="@style/Widget.MangaTranslator.BodyMuted" />

    </LinearLayout>

</ScrollView>
