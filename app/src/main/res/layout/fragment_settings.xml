<?xml version="1.0" encoding="utf-8"?>
<com.manga.translate.SafeNestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:paddingStart="16dp"
    android:paddingTop="8dp"
    android:paddingEnd="16dp"
    android:paddingBottom="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:background="@drawable/bg_surface_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_group_api"
                android:textAppearance="@style/Widget.MangaTranslator.SectionLabel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_group_api_title"
                android:textAppearance="@style/Widget.MangaTranslator.CardTitle" />

            <TextView
                android:id="@+id/api_url_hint_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/api_settings_note_openai"
                android:textAppearance="@style/Widget.MangaTranslator.BodyMuted" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/api_url_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/api_url_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/api_url_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/api_format_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/api_format_button" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/api_key_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/api_key_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/api_key_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/model_name_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/model_name_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/model_name_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/api_timeout_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/api_timeout_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/api_timeout_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/ai_provider_profiles_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/ai_provider_profiles_button" />

            <Button
                android:id="@+id/fetch_models_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/fetch_models" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_surface_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_group_translation"
                android:textAppearance="@style/Widget.MangaTranslator.SectionLabel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_group_translation_title"
                android:textAppearance="@style/Widget.MangaTranslator.CardTitle" />

            <Button
                android:id="@+id/llm_params_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/llm_params_button" />

            <Button
                android:id="@+id/custom_request_params_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/custom_request_params_button" />

            <Button
                android:id="@+id/ocr_settings_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/ocr_settings_button" />

            <Button
                android:id="@+id/floating_translate_settings_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/floating_translate_settings_button" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/max_concurrency_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:hint="@string/max_concurrency_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/max_concurrency_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/translation_bubble_opacity_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/translation_bubble_opacity_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/translation_bubble_opacity_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/bubble_conf_threshold_layout"
                style="@style/Widget.MangaTranslator.Input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/bubble_conf_threshold_hint">

                <com.google.android.material.textfield.TextInputEditText
                    style="@style/Widget.MangaTranslator.EditText"
                    android:id="@+id/bubble_conf_threshold_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_surface_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_group_experience"
                android:textAppearance="@style/Widget.MangaTranslator.SectionLabel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_group_experience_title"
                android:textAppearance="@style/Widget.MangaTranslator.CardTitle" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/text_layout_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="?attr/dialogTextColor"
                android:text="@string/text_layout_horizontal" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/model_io_logging_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?attr/dialogTextColor"
                android:text="@string/model_io_logging" />

            <Button
                android:id="@+id/theme_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/theme_setting_button" />

            <Button
                android:id="@+id/language_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/language_setting_button" />

            <Button
                android:id="@+id/reading_display_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/reading_display_button" />

            <Button
                android:id="@+id/reading_page_animation_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/reading_page_animation_button" />

            <Button
                android:id="@+id/link_source_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/link_source_button" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_surface_card"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_group_support"
                android:textAppearance="@style/Widget.MangaTranslator.SectionLabel" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/settings_group_support_title"
                android:textAppearance="@style/Widget.MangaTranslator.CardTitle" />

            <Button
                android:id="@+id/about_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/about_button" />

            <Button
                android:id="@+id/view_logs_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/view_logs" />

            <Button
                android:id="@+id/open_logs_folder_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"
                android:text="@string/share_logs" />
        </LinearLayout>
    </LinearLayout>
</com.manga.translate.SafeNestedScrollView>
