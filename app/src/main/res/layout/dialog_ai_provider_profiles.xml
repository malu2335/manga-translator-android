<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <TextView
        android:id="@+id/ai_provider_profiles_current_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/Widget.MangaTranslator.BodyMuted"
        android:textColor="?attr/dialogTextColor" />

    <TextView
        android:id="@+id/ai_provider_profiles_note_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textAppearance="@style/Widget.MangaTranslator.BodyMuted"
        android:textColor="?attr/dialogTextColor" />

    <ListView
        android:id="@+id/ai_provider_profiles_list"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_marginTop="12dp"
        android:choiceMode="singleChoice"
        android:divider="@android:color/transparent"
        android:dividerHeight="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/ai_provider_profiles_apply_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ai_provider_profiles_apply" />

        <Button
            android:id="@+id/ai_provider_profiles_save_new_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ai_provider_profiles_save_new" />

        <Button
            android:id="@+id/ai_provider_profiles_overwrite_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ai_provider_profiles_overwrite" />

        <Button
            android:id="@+id/ai_provider_profiles_delete_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/ai_provider_profiles_delete" />
    </LinearLayout>

</LinearLayout>
